      <aliases enabled='yes' />
      <column caption='Delivery status' datatype='string' name='[Calculation_1564397241511936]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;Fast&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Order status(profit)' datatype='string' name='[Calculation_1564397243412481]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Product rank' datatype='integer' name='[Calculation_1564397246455810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-field='[federated.0dnoxz30lq6bg013ixkru0v3yhw4].[Product_Name]' ordering-type='Field' />
