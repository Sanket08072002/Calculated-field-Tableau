        </calculation>
      </column>
      <column caption='City avg sales' datatype='real' name='[Calculation_1564397256880137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
      </column>
      <column caption='Avg product sales' datatype='real' name='[Calculation_1564397259952138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({ INCLUDE [Product_Name]:SUM([Sales]) })' />
